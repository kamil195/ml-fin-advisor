[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "ml-fin-advisor"
version = "0.1.0"
description = "Personal Finance Advisor with Behavior Modeling — Supervised Learning for Transaction Classification, Expense Forecasting, and Budget Recommendations"
readme = "README.md"
license = { text = "MIT" }
requires-python = ">=3.11"
authors = [{ name = "ML Fin-Tech Team" }]

dependencies = [
    # ── Core Scientific Stack ──────────────────────────────────────
    "numpy>=1.26,<2.0",
    "pandas>=2.2,<3.0",
    "scipy>=1.12,<2.0",

    # ── ML Frameworks ──────────────────────────────────────────────
    "torch>=2.2,<3.0",
    "scikit-learn>=1.4,<2.0",
    "xgboost>=2.0,<3.0",
    "lightgbm>=4.3,<5.0",

    # ── NLP & Embeddings ───────────────────────────────────────────
    "sentence-transformers>=3.0,<4.0",
    "transformers>=4.40,<5.0",

    # ── Time-Series Forecasting ────────────────────────────────────
    "prophet>=1.1,<2.0",
    "neuralforecast>=1.7,<2.0",

    # ── Interpretability / Explainability ──────────────────────────
    "shap>=0.45,<1.0",
    "alibi>=0.9,<1.0",
    "lime>=0.2,<1.0",

    # ── Serving & API ──────────────────────────────────────────────
    "fastapi>=0.110,<1.0",
    "uvicorn[standard]>=0.29,<1.0",
    "onnxruntime>=1.17,<2.0",
    "pydantic>=2.6,<3.0",

    # ── Data Validation ────────────────────────────────────────────
    "great-expectations>=0.18,<1.0",

    # ── Experiment Tracking & Feature Store ────────────────────────
    "mlflow>=2.11,<3.0",
    "feast>=0.38,<1.0",

    # ── Storage & Caching ──────────────────────────────────────────
    "redis>=5.0,<6.0",
    "pyarrow>=15.0,<17.0",

    # ── Utilities ──────────────────────────────────────────────────
    "holidays>=0.46,<1.0",
    "tqdm>=4.66,<5.0",
    "pyyaml>=6.0,<7.0",
    "python-dotenv>=1.0,<2.0",
    "structlog>=24.1,<25.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.1,<9.0",
    "pytest-cov>=5.0,<6.0",
    "pytest-asyncio>=0.23,<1.0",
    "httpx>=0.27,<1.0",            # For FastAPI test client
    "ruff>=0.3,<1.0",
    "mypy>=1.9,<2.0",
    "pre-commit>=3.7,<4.0",
    "ipykernel>=6.29,<7.0",
    "jupyter>=1.0,<2.0",
    "matplotlib>=3.8,<4.0",
    "seaborn>=0.13,<1.0",
]

infra = [
    "apache-airflow>=2.8,<3.0",
    "prefect>=2.16,<3.0",
    "evidently>=0.4,<1.0",
    "dvc>=3.48,<4.0",
]

[project.scripts]
fin-advisor-serve = "src.serving.app:main"

# ── Tool Configuration ─────────────────────────────────────────────

[tool.ruff]
target-version = "py311"
line-length = 100

[tool.ruff.lint]
select = ["E", "F", "I", "N", "W", "UP", "B", "SIM", "RUF"]
ignore = ["E501"]

[tool.ruff.lint.isort]
known-first-party = ["src"]

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["."]
addopts = "-v --tb=short --strict-markers"
markers = [
    "slow: marks tests as slow (deselect with '-m \"not slow\"')",
    "integration: marks integration tests",
]

[tool.mypy]
python_version = "3.11"
warn_return_any = true
warn_unused_configs = true
disallow_untyped_defs = true
plugins = ["pydantic.mypy"]
